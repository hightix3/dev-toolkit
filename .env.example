# ============================================
# Free Dev Toolkit - Environment Configuration
# ============================================
# Copy this file to .env and fill in your API keys.
# All services below have free tiers — no credit card required.

# --- Blockfrost (Cardano API) ---
# Sign up: https://blockfrost.io
# Create a project → copy API key
BLOCKFROST_PROJECT_ID=your_blockfrost_api_key_here
BLOCKFROST_NETWORK=testnet
# Options: mainnet, testnet, preview, preprod

# --- Supabase (PostgreSQL) ---
# Sign up: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- MongoDB Atlas ---
# Sign up: https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/mydb

# --- Sentry (Error Tracking) ---
# Sign up: https://sentry.io
SENTRY_DSN=https://your_key@o000000.ingest.sentry.io/0000000

# --- General ---
PYTHON_ENV=development
LOG_LEVEL=INFO
DATA_DIR=./data
